# Context Service Environment Configuration
# Copy to .env and fill in values

# =============================================================================
# Service
# =============================================================================
SERVICE_NAME=context-service
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=false

# =============================================================================
# Graph Database (Memgraph)
# =============================================================================
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# =============================================================================
# Vector Database (Qdrant)
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Embeddings
# =============================================================================
# Jina AI embeddings
JINA_API_KEY=

# Google Vertex AI
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# =============================================================================
# LLM Providers
# =============================================================================
# Path to GCP service account JSON (for Vertex AI)
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini API key (alternative to service account)
GEMINI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (optional, for compatibility)
OPENAI_API_KEY=

# Default model for LLM calls
DEFAULT_LLM_MODEL=gemini-2.0-flash

# =============================================================================
# Observability
# =============================================================================
# OpenTelemetry collector endpoint (leave empty to disable)
OTEL_ENDPOINT=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# Auth
# =============================================================================
AUTH_ENABLED=false                 # dev only; production must be true
ENVIRONMENT=dev                    # dev | staging | production
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# DEV_ORG_ID=dev-org
# DEV_USER_ID=dev-user
# MCP_DEV_TOKEN=                   # stop-gap token for authenticated MCP dev access
