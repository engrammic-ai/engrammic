# Context Service Environment Configuration
# Copy to .env and fill in values

# =============================================================================
# Service
# =============================================================================
SERVICE_NAME=context-service
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=false

# =============================================================================
# Graph Database (Memgraph)
# =============================================================================
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# =============================================================================
# Vector Database (Qdrant)
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Postgres (tag configuration)
# =============================================================================
INFRA__POSTGRES__HOST=localhost
INFRA__POSTGRES__PORT=5432
INFRA__POSTGRES__USER=context
INFRA__POSTGRES__PASSWORD=context
INFRA__POSTGRES__DATABASE=context_service

# =============================================================================
# Embeddings
# =============================================================================
# Jina AI embeddings
JINA_API_KEY=

# Google Vertex AI
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# =============================================================================
# LLM Providers
# =============================================================================
# Path to GCP service account JSON (for Vertex AI)
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini API key (alternative to service account)
GEMINI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (optional, for compatibility)
OPENAI_API_KEY=

# Default model for LLM calls
DEFAULT_LLM_MODEL=gemini-2.0-flash

# =============================================================================
# Document Expansion (search quality improvement)
# =============================================================================
EXPANSION_GENERATION_ENABLED=true
EXPANSION_LLM_PROVIDER=vertex     # vertex, anthropic, openai, gemini
EXPANSION_LLM_MODEL=              # leave empty to use DEFAULT_LLM_MODEL

# =============================================================================
# Observability
# =============================================================================
# OpenTelemetry collector endpoint (leave empty to disable)
OTEL_ENDPOINT=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# Auth
# =============================================================================
# AUTH_ENABLED=false               # production must set true; ENVIRONMENT is set above
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# DEV_ORG_ID=dev-org
# DEV_USER_ID=dev-user
# MCP_DEV_TOKEN=                   # stop-gap token for authenticated MCP dev access

# =============================================================================
# Signals (heat, freshness, priority)
# =============================================================================
# Feature flags (all default OFF for gradual rollout)
HEAT_RANKING_ENABLED=false
UNIFIED_DECAY_ENABLED=false
WRITE_EVENTS_ENABLED=false

# Tuning knobs
HEAT_WEIGHT=0.1
HEAT_HALF_LIFE_DAYS=7
HEAT_READ_WEIGHT=1.0
HEAT_WRITE_WEIGHT=0.5
HEAT_DEDUP_WINDOW_SECONDS=300
