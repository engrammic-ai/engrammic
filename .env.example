# Context Service Environment Configuration
# Copy to .env and fill in values

# =============================================================================
# Service
# =============================================================================
SERVICE_NAME=context-service
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=false

# =============================================================================
# Graph Database (Memgraph)
# =============================================================================
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# =============================================================================
# Vector Database (Qdrant)
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Postgres (tag configuration)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=context
POSTGRES_PASSWORD=context
POSTGRES_DATABASE=context_service

# =============================================================================
# Embeddings (via LiteLLM or provider-specific clients)
# =============================================================================
# Provider: jina, vertex, litellm
EMBEDDING_PROVIDER=jina

# Jina AI embeddings
JINA_API_KEY=

# LiteLLM embeddings (unified provider access)
# Model format: "vertex_ai/text-embedding-005", "openai/text-embedding-3-small"
LITELLM_EMBEDDING_MODEL=vertex_ai/text-embedding-005
EMBEDDING_DIMENSIONS=768

# =============================================================================
# LLM Providers (via LiteLLM - unified access to all providers)
# =============================================================================
# LiteLLM handles provider-specific API differences automatically.
# Just set the API key for your chosen provider.

# Provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Google Vertex AI (uses Application Default Credentials)
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# Self-hosted LLMs (Ollama, vLLM)
OLLAMA_BASE_URL=http://localhost:11434

# Default provider and model
LLM_PROVIDER=gemini                    # anthropic, openai, gemini, vertex_gemini, ollama
DEFAULT_LLM_MODEL=gemini-2.0-flash

# =============================================================================
# Document Expansion (search quality improvement)
# =============================================================================
EXPANSION_GENERATION_ENABLED=true
EXPANSION_LLM_PROVIDER=vertex     # vertex, anthropic, openai, gemini
EXPANSION_LLM_MODEL=              # leave empty to use DEFAULT_LLM_MODEL

# =============================================================================
# Telemetry (self-hosted deployments)
# =============================================================================
# Tier 1 (anonymous aggregate): enabled by default
# Tier 2 (per-silo): opt-in via TELEMETRY__SILOS
TELEMETRY__ENABLED=true
TELEMETRY__SILOS=                       # comma-separated silo IDs, or "*" for all
TELEMETRY__BEACON_URL=https://tel.engrammic.com/v1/beacon
TELEMETRY__BEACON_INTERVAL_HOURS=24

# =============================================================================
# Observability
# =============================================================================
# OpenTelemetry collector endpoint (leave empty to disable)
OTEL_ENDPOINT=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# Auth
# =============================================================================
# AUTH_ENABLED=false               # production must set true; ENVIRONMENT is set above
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# DEV_ORG_ID=dev-org
# DEV_USER_ID=dev-user
# MCP_DEV_TOKEN=                   # stop-gap token for authenticated MCP dev access

# =============================================================================
# Signals (heat, freshness, priority)
# =============================================================================
# Feature flags (all default OFF for gradual rollout)
HEAT_RANKING_ENABLED=false
UNIFIED_DECAY_ENABLED=false
WRITE_EVENTS_ENABLED=false

# Tuning knobs
HEAT_WEIGHT=0.1
HEAT_HALF_LIFE_DAYS=7
HEAT_READ_WEIGHT=1.0
HEAT_WRITE_WEIGHT=0.5
HEAT_DEDUP_WINDOW_SECONDS=300
