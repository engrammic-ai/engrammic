# Context Service Environment Configuration
# Copy to .env and fill in values
#
# NOTE: keep comments on their own line. Docker Compose env_file loads values
# verbatim (it does not strip inline "VALUE  # comment"), which breaks typed
# settings like TELEMETRY__SILOS (list) and *_INTERVAL_HOURS (int).

# =============================================================================
# Service
# =============================================================================
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=false

# =============================================================================
# Graph Database (Memgraph)
# =============================================================================
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# =============================================================================
# Vector Database (Qdrant)
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# Postgres (tag configuration)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=context
POSTGRES_PASSWORD=context
POSTGRES_DATABASE=engrammic

# =============================================================================
# Embeddings (via LiteLLM - unified access to all providers)
# =============================================================================
# LiteLLM handles embedding provider differences automatically.
# Model format: "vertex_ai/text-embedding-005", "openai/text-embedding-3-small", "jina_ai/jina-embeddings-v3"
LITELLM_EMBEDDING_MODEL=vertex_ai/gemini-embedding-001
EMBEDDING_DIMENSIONS=2048

# Jina AI (only if using jina_ai/* models)
JINA_API_KEY=

# =============================================================================
# LLM Providers (via LiteLLM - unified access to all providers)
# =============================================================================
# LiteLLM handles provider-specific API differences automatically.
# Just set the API key for your chosen provider.

# Provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Google Vertex AI (uses Application Default Credentials)
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=europe-north1

# Self-hosted LLMs (Ollama, vLLM)
OLLAMA_BASE_URL=http://localhost:11434

# Default provider and model
# LLM_PROVIDER options: anthropic, openai, gemini, vertex_gemini, ollama
LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-3.1-flash-lite

# =============================================================================
# Document Expansion (search quality improvement)
# =============================================================================
EXPANSION_GENERATION_ENABLED=true

# =============================================================================
# Telemetry (beacon heartbeats to Engrammic)
# =============================================================================
# Tier 1 (anonymous aggregate): enabled by default
# Tier 2 (per-silo): opt-in via TELEMETRY__SILOS
TELEMETRY__ENABLED=true
# TELEMETRY__SILOS: comma-separated silo IDs, or "*" for all (empty = tier 1 only)
TELEMETRY__SILOS=
TELEMETRY__BEACON_URL=https://tel.engrammic.ai/v1/beacon
# TELEMETRY__BEACON_SECRET: auth secret for the beacon service
TELEMETRY__BEACON_SECRET=
# TELEMETRY__BEACON_INTERVAL_HOURS: heartbeat interval (default 1)
TELEMETRY__BEACON_INTERVAL_HOURS=1

# =============================================================================
# Observability
# =============================================================================
# OTEL (optional, for local tracing with Jaeger/Tempo)
# Leave empty to disable OTEL tracing
OTEL_EXPORTER_OTLP_ENDPOINT=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# Auth (required for beta/prod)
# =============================================================================
AUTH_ENABLED=false
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
# DEV_ORG_ID=dev-org
# DEV_USER_ID=dev-user
# DEV_AGENT_ID=dev-agent

# =============================================================================
# Embeddings Provider
# =============================================================================
EMBEDDING_PROVIDER=vertex
# EMBEDDING_PROVIDER=jina  # alternative for local dev

# =============================================================================
# Custodian Pipeline
# =============================================================================
CUSTODIAN__ENABLED=false

# =============================================================================
# Signals (heat, freshness, priority)
# =============================================================================
# Feature flags (all default OFF for gradual rollout)
HEAT_RANKING_ENABLED=false
UNIFIED_DECAY_ENABLED=false
WRITE_EVENTS_ENABLED=false

# Tuning knobs
HEAT_WEIGHT=0.1
HEAT_HALF_LIFE_DAYS=7
HEAT_READ_WEIGHT=1.0
HEAT_WRITE_WEIGHT=0.5
HEAT_DEDUP_WINDOW_SECONDS=300

# =============================================================================
# Epistemic Fusion (read path)
# =============================================================================
# Confidence and conflict state scale post-rerank relevance so evidence is
# load-bearing at recall time.
# EPISTEMIC_FUSION__ENABLED=true
# EPISTEMIC_FUSION__CONFIDENCE_WEIGHT=0.3
# EPISTEMIC_FUSION__CONFLICT_PENALTY=0.5
