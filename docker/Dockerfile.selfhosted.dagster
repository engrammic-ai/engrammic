# Self-hosted Dagster image - Cython compiled for IP protection
# Runs SAGE pipelines: custodian, synthesizer, groundskeeper

# Stage 1: Cython compilation
FROM python:3.13-slim AS compiler

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    python3-dev \
    ccache \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/usr/lib/ccache:$PATH"
ENV CCACHE_DIR=/ccache

RUN pip install --no-cache-dir cython setuptools

COPY src/ /build/src/
COPY scripts/compile_cython.py /build/scripts/

RUN --mount=type=cache,target=/ccache \
    python /build/scripts/compile_cython.py /build/src/context_service

RUN remaining=$(find /build/src/context_service -name "*.py" ! -name "__init__.py" | wc -l) && \
    [ "$remaining" -eq 0 ] || (echo "ERROR: Uncompiled files remain" && exit 1)

# Stage 2: Dependencies
FROM python:3.13-slim AS builder

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:0.6.14 /uv /usr/local/bin/uv

COPY pyproject.toml uv.lock README.md ./

ENV UV_LINK_MODE=copy
ENV UV_COMPILE_BYTECODE=1

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project \
      --group graph --group postgres --group redis --group llm-core \
      --group numeric --group pipelines --group custodian

# Stage 3: Runtime
FROM python:3.13-slim

WORKDIR /app

RUN groupadd -g 1000 dagster && useradd -u 1000 -g dagster -m dagster

COPY --from=builder /app/.venv /app/.venv

# Copy COMPILED source
COPY --from=compiler /build/src/ /app/src/

COPY pyproject.toml dagster.yaml workspace.yaml ./
COPY config/ /app/config/
COPY scripts/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app/src"
ENV DAGSTER_HOME="/app"
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV ENGRAMMIC_DEPLOYMENT_TYPE=selfhosted

RUN chown -R dagster:dagster /app

USER dagster

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:3000/server_info')"

ENTRYPOINT ["/entrypoint.sh"]
CMD ["dagster-webserver", "-h", "0.0.0.0", "-p", "3000", "-m", "context_service.pipelines.definitions"]
