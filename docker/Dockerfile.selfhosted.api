# Self-hosted API image - Cython compiled for IP protection
# Internal use: docker/Dockerfile.api (keeps .py source for debugging)
#
# Cython compiles Python to native .so binaries which are much harder
# to reverse engineer than .pyc bytecode.

# Stage 1: Cython compilation
FROM python:3.13-slim AS compiler

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    python3-dev \
    ccache \
    && rm -rf /var/lib/apt/lists/*

# ccache speeds up repeated compilations
ENV PATH="/usr/lib/ccache:$PATH"
ENV CCACHE_DIR=/ccache

RUN pip install --no-cache-dir cython setuptools

COPY src/ /build/src/
COPY scripts/compile_cython.py /build/scripts/

# Compile to native .so files (ccache speeds rebuilds)
RUN --mount=type=cache,target=/ccache \
    python /build/scripts/compile_cython.py /build/src/context_service

# Verify compilation succeeded
RUN remaining=$(find /build/src/context_service -name "*.py" ! -name "__init__.py" | wc -l) && \
    echo "Remaining .py files: $remaining" && \
    [ "$remaining" -eq 0 ] || (echo "ERROR: Uncompiled files remain" && exit 1)

# Stage 2: Dependencies
FROM python:3.13-slim AS builder

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:0.6.14 /uv /usr/local/bin/uv

COPY pyproject.toml uv.lock README.md ./

ENV UV_LINK_MODE=copy
ENV UV_COMPILE_BYTECODE=1

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project \
      --group api --group mcp --group graph --group postgres \
      --group redis --group llm-core --group numeric --group auth

# Stage 3: Runtime
FROM python:3.13-slim

WORKDIR /app

RUN groupadd -g 1000 engrammic && useradd -u 1000 -g engrammic -m engrammic

COPY --from=builder /app/.venv /app/.venv

# Copy COMPILED source (only .so + __init__.py)
COPY --from=compiler /build/src/ /app/src/

COPY pyproject.toml uv.lock README.md ./
COPY config/ /app/config/
COPY alembic.ini /app/alembic.ini
COPY alembic/ /app/alembic/
COPY skills/ /app/skills/

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app/src"
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV ENGRAMMIC_DEPLOYMENT_TYPE=selfhosted

USER engrammic

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"

CMD ["python", "-m", "context_service.entrypoint"]
