# Engrammic Self-Hosted Configuration

# Required: Your license key
ENGRAMMIC_LICENSE_KEY=ENGR_your_license_key_here

# Database passwords (defaults work for local dev, change in production)
POSTGRES_PASSWORD=engrammic

# =============================================================================
# REQUIRED: Embedding provider (pick one)
# =============================================================================
# Without embeddings, remember/learn/recall will fail.
# Uses LiteLLM - see https://docs.litellm.ai/docs/embedding/supported_embedding

# Option 1: OpenAI (recommended)
EMBEDDING_MODEL=openai/text-embedding-3-small
OPENAI_API_KEY=sk-...

# Option 2: Azure OpenAI
# EMBEDDING_MODEL=azure/text-embedding-ada-002
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com

# Option 3: AWS Bedrock
# EMBEDDING_MODEL=bedrock/amazon.titan-embed-text-v2:0
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# Option 4: Google Vertex AI (requires gcloud credentials mount)
# EMBEDDING_MODEL=vertex_ai/text-embedding-005
# VERTEX_PROJECT=your-project
# VERTEX_LOCATION=us-central1

# Option 5: Local via Ollama
# EMBEDDING_MODEL=ollama/nomic-embed-text
# OLLAMA_API_BASE=http://host.docker.internal:11434

# EMBEDDING_DIMENSIONS must match the model (768 for nomic and text-embedding-005,
# 384 for all-MiniLM-L6-v2). Default is 768. Changing it after data exists requires
# recreating Qdrant collections and re-embedding.
# EMBEDDING_DIMENSIONS=768

# =============================================================================
# OPTIONAL: LLM for SAGE synthesis
# =============================================================================
# Without a provider configured, SAGE runs in passive mode (storage + recall only,
# no synthesis). Set the provider and its credentials here. The model itself is
# chosen in config/models.yaml, not via an env var.
#
# Pick one:
# LLM_PROVIDER=openai      # then OPENAI_API_KEY
# LLM_PROVIDER=anthropic   # then ANTHROPIC_API_KEY
# LLM_PROVIDER=gemini      # then GEMINI_API_KEY
# LLM_PROVIDER=vertex      # then VERTEX_PROJECT + VERTEX_LOCATION (gcloud mount)
# LLM_PROVIDER=ollama      # then OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# Note: the LLM path uses OLLAMA_BASE_URL, the embedding path uses OLLAMA_API_BASE.
# They are different variables.

# Anonymous usage statistics (set to false to opt out)
TELEMETRY__ENABLED=true
