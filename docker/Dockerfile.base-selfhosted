# Base image for self-hosted builds
# Contains: Python deps + Cython compiler toolchain
# Rebuild when: pyproject.toml changes or new Cython version needed

FROM python:3.13-slim

WORKDIR /app

# Install Cython build deps (kept in base for faster rebuilds)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir cython setuptools

COPY --from=ghcr.io/astral-sh/uv:0.6.14 /uv /usr/local/bin/uv

COPY pyproject.toml uv.lock README.md ./

ENV UV_LINK_MODE=copy
ENV UV_COMPILE_BYTECODE=1

# Install all deps including reranking (self-hosted pro needs it)
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project \
      --group api --group mcp --group graph --group postgres \
      --group redis --group llm-core --group numeric --group auth \
      --group reranking
