# docker/standalone-pro.env.example
# Engrammic Standalone - Pro Tier Configuration
# Copy to standalone-pro.env and customize

# Database password (change in production!)
POSTGRES_PASSWORD=engrammic

# License key (required for self-hosted)
# ENGRAMMIC_LICENSE_KEY=your-license-key

# Optional: Override default models
# OLLAMA_MODEL=gemma4:26b
# TEI_MODEL=nomic-ai/nomic-embed-text-v2-moe
# TEI_RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual
